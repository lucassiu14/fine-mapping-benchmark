# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown generated site (not hand-written docs in docs/)
docs/reference/
docs/articles/
docs/news/
docs/index.html

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# macOS metadata
.DS_Store

# Benchmark outputs
results/

# Claude Code settings (local only)
.claude/

# Downloaded 1000 Genomes VCF files (regenerate with inst/scripts/prepare_vcfs.R)
data/vcf/*.vcf.gz
data/vcf/*.vcf.gz.tbi

# Cached HapMap GRCh37 genetic maps (downloaded automatically by sim1000G)
data/genetic_maps/*.txt.gz

# sim1000G cache written when tests run with cwd = tests/testthat/
tests/testthat/data/

# CARMA writes per-locus working files to the current directory
post_locus_*

# Python bytecode and BEATRICE scratch
__pycache__/
*.pyc
BEATRICE_annot_sparse/temp/

# Editor swap files
*.swp
*.swo
*~

# Auto-generated test report (regenerated by scripts/test_comprehensive.R;
# reflects local env, not authoritative)
docs/testing_report.md
